generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model College {
  id            Int      @id @default(autoincrement())
  name          String
  location      String
  city          String
  state         String
  fees          Int
  rating        Float
  placementRate Float
  avgPackage    Float
  courses       String[]
  type          String
  established   Int
  totalStudents Int
  image         String?
  description   String
  accreditation String
  topRecruiters String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}